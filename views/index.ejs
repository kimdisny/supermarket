<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>ระบบจัดการสินค้า</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛒 รายการสินค้า</h2>
    <a href="/create" class="btn btn-primary">+ เพิ่มสินค้า</a>
  </div>

  <table class="table table-bordered table-striped shadow">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>รูปภาพ</th>
        <th>ชื่อสินค้า</th>
        <th>ราคา</th>
        <th>หมวดหมู่</th>
        <th>สต็อก</th>
        <th>จัดการ</th>
      </tr>
    </thead>
    <tbody>
      <% if (products.length === 0) { %>
        <tr><td colspan="7" class="text-center">ไม่มีสินค้า</td></tr>
      <% } %>
      <% products.forEach((product, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <% if (product.image) { %>
              <img src="/uploads/<%= product.image %>" width="60" class="img-thumbnail">
            <% } else { %>
              <span class="text-muted">ไม่มีรูป</span>
            <% } %>
          </td>
          <td><%= product.name %></td>
          <td><%= product.price %> บาท</td>
          <td><%= product.category %></td>
          <td><%= product.stock %></td>
          <td>
            <a href="/edit/<%= product.id %>" class="btn btn-warning btn-sm">แก้ไข</a>
            <form action="/delete/<%= product.id %>" method="POST" style="display:inline"
                  onsubmit="return confirm('ยืนยันการลบ?')">
              <button type="submit" class="btn btn-danger btn-sm">ลบ</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
</body>
</html>